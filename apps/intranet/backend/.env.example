# Copy to .env (gitignored). Loaded by app.py via python-dotenv.

# Local Postgres — matches docker-compose (published on host port 5433).
# Inside Docker, use the service host instead: ...@omni_intranet_db:5432/omni_intranet
DATABASE_URL=postgresql+psycopg2://omni_intranet_user:omni_intranet_pass26@localhost:5433/omni_intranet

# Auth0 — from your Auth0 tenant (API + Application settings)
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://api.omni.adept

# Flask CLI
FLASK_APP=app.py
FLASK_DEBUG=1
